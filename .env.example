# Convex deployment URL (auto-set by `npx convex dev`)
VITE_CONVEX_URL=https://your-project.convex.cloud

# Razorpay Public Key (safe to expose on frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Razorpay credentials for Convex backend (NEVER expose on frontend)
# Set these via: npx convex env set RAZORPAY_KEY_ID rzp_test_xxx
# Set these via: npx convex env set RAZORPAY_KEY_SECRET your_secret
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
